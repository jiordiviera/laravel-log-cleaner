{
  "name": "jiordiviera/laravel-log-cleaner",
  "description": "A Laravel package to easily clean the log files.",
  "version": "2.1.0",
  "keywords": [
    "laravel",
    "log",
    "cleaner",
    "logging",
    "log management",
    "laravel package",
    "maintenance",
    "log files",
    "artisan"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Jiordi Viera",
      "email": "jiordikengne@gmail.com",
      "role": "Owner",
      "homepage": "https://github.com/jiordiviera"
    }
  ],
  "require": {
    "php": "^8.2|^8.3",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
    "pestphp/pest": "^1.23|^2.0|^3.0",
    "pestphp/pest-plugin-laravel": "^1.4|^2.0|^3.0",
    "phpstan/phpstan": "^2.1"
  },
  "suggest": {
    "larastan/larastan": "^2.0 for Laravel 9-10 or ^3.0 for Laravel 11-13"
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "analyse": "vendor/bin/phpstan analyse -c phpstan.neon",
    "format": "vendor/bin/pint",
    "lint": "vendor/bin/pint --test"
  },
  "autoload": {
    "psr-4": {
      "JiordiViera\\LaravelLogCleaner\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JiordiViera\\LaravelLogCleaner\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "JiordiViera\\LaravelLogCleaner\\LaravelLogCleanerServiceProvider"
      ],
      "aliases": {
        "LogCleaner": "JiordiViera\\LaravelLogCleaner\\LogCleanerFacade"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  }
}
